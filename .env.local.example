# Local development env. Copy to ".env.local" (which is gitignored) and fill in.
# Values come from your Supabase project: Settings -> API.

# Public — safe to expose to the browser (used by the SSR + browser clients).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Wearable sync (Fitbit steps + sleep via the Google Health API). Optional.
# Full setup guide: docs/google-health-setup.md
# Required for manual "Sync now":
# GOOGLE_HEALTH_CLIENT_ID=
# GOOGLE_HEALTH_CLIENT_SECRET=
# GOOGLE_HEALTH_REDIRECT_URI=http://localhost:3000/api/wearables/google/callback
# WEARABLE_TOKEN_ENC_KEY=   # node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required for the scheduled 4x/day Vercel Cron (/api/cron/wearable-sync); manual
# "Sync now" doesn't need these:
# CRON_SECRET=                  # node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SUPABASE_SERVICE_ROLE_KEY=    # server-only; the cron writes without a session

# AI features (OpenAI). The same key powers BOTH the structured AI overview
# (Progress/Goals/Today) and the floating coach chat. Both are restricted to the
# comma-separated emails in ANALYSIS_ALLOWED_EMAILS.
OPENAI_API_KEY=
OPENAI_ANALYSIS_MODEL=gpt-5.4
# Optional — model for the coach chat; falls back to OPENAI_ANALYSIS_MODEL.
# OPENAI_CHAT_MODEL=gpt-5.4
ANALYSIS_ALLOWED_EMAILS=cameronwoodard1121@gmail.com
