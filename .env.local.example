# Local development env. Copy to ".env.local" (which is gitignored) and fill in.
# Values come from your Supabase project: Settings -> API.

# Public — safe to expose to the browser (used by the SSR + browser clients).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — server-only service role key. NEVER expose this to the browser.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI training overview (OpenAI). These gate + power the structured AI overview
# that feeds Progress, Goals, and the Today focus nudge. The feature is
# restricted to the comma-separated emails in ANALYSIS_ALLOWED_EMAILS.
OPENAI_API_KEY=
OPENAI_ANALYSIS_MODEL=gpt-5.4
ANALYSIS_ALLOWED_EMAILS=cameronwoodard1121@gmail.com
