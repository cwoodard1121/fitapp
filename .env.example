# Supabase project credentials.
# Copy this file to ".env.local" and fill in the values from your Supabase
# project: Settings -> API. Restart the dev server after changing env vars.

# Public — safe to expose to the browser (used by the SSR + browser clients).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — server-only service role key. NEVER expose this to the browser.
# Only needed for privileged server-side maintenance scripts; the app's normal
# read/write paths rely on RLS + the anon key with the user's session.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
