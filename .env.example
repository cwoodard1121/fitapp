# Supabase project credentials.
# Copy this file to ".env.local" and fill in the values from your Supabase
# project: Settings -> API. Restart the dev server after changing env vars.

# Public — safe to expose to the browser (used by the SSR + browser clients).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Wearable sync (Fitbit steps + sleep via the Google Health API). Optional —
# the app works without it; the Settings "Connect Fitbit" card stays inert until
# these are set. Full setup guide: docs/google-health-setup.md
#
# Required for the manual "Sync now" flow:
# GOOGLE_HEALTH_CLIENT_ID=
# GOOGLE_HEALTH_CLIENT_SECRET=
# GOOGLE_HEALTH_REDIRECT_URI=https://your-domain/api/wearables/google/callback
# 32-byte base64 key encrypting wearable tokens at rest:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WEARABLE_TOKEN_ENC_KEY=
#
# ONLY needed to automate the optional /api/cron/wearable-sync route via an
# external scheduler — manual "Sync now" does NOT need these:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRON_SECRET=
# Server-only service role key (NEVER expose to the browser); lets the sync route
# write without a user session. Also used by privileged maintenance scripts.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI features (OpenAI). The same key powers BOTH the structured AI overview
# (Progress/Goals/Today) and the floating coach chat. Both are restricted to the
# comma-separated emails in ANALYSIS_ALLOWED_EMAILS.
OPENAI_API_KEY=
OPENAI_ANALYSIS_MODEL=gpt-5.4
# Optional — model for the coach chat; falls back to OPENAI_ANALYSIS_MODEL.
# OPENAI_CHAT_MODEL=gpt-5.4
ANALYSIS_ALLOWED_EMAILS=cameronwoodard1121@gmail.com
